# =======================================
# TaskMate Backend - Environment Variables
# =======================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git - it contains sensitive data

# Server Configuration
PORT=4000
NODE_ENV=production

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=ClusterName

# Frontend URL (CORS Configuration)
# Set this to your Vercel frontend URL after deployment
FRONTEND_URL=https://your-frontend.vercel.app

# JWT Configuration
JWT_SECRET=your_secret_key_here_min_32_chars_recommended
JWT_EXPIRE=7d
COOKIE_EXPIRE=3

# Email Configuration (Gmail SMTP)
SMPT_HOST=smtp.gmail.com
SMPT_SERVICE=gmail
SMPT_PORT=465
SMPT_MAIL=your_email@gmail.com
SMPT_PASSWORD=your_app_password_here
# Note: Use Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# =======================================
# Deployment Platform: Render
# =======================================
# 1. Create a new Web Service on render.com
# 2. Connect your GitHub repository
# 3. Set Build Command: npm install
# 4. Set Start Command: npm start
# 5. Set Root Directory: backend
# 6. Add all these environment variables in Render dashboard
# 7. Deploy and get your backend URL (https://your-backend.onrender.com)

# =======================================
# After Deployment
# =======================================
# Update FRONTEND_URL with your actual Vercel URL
# Update frontend's VITE_API_URL to your Render backend URL
